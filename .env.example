# PostgreSQL settings for local Docker Compose.
POSTGRES_DB=webhook_pipeline
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Database connection string used by API and worker containers.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/webhook_pipeline

# API service port.
API_PORT=3000

# Worker poll interval in milliseconds.
WORKER_POLL_INTERVAL_MS=5000
