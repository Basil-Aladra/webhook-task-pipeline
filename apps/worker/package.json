{
  "name": "@webhook-pipeline/worker",
  "version": "1.0.0",
  "private": true,
  "description": "Background worker service for job polling and task execution.",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:recovery": "ts-node src/modules/jobs/jobs.recovery.test.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
